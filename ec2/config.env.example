# AWS and storage
export CHINCHE_BUCKET="eagriculturai-chinche"
export AWS_REGION="us-east-1"
export CHINCHE_IMAGE="<account>.dkr.ecr.us-east-1.amazonaws.com/chinche-training:latest"
export CHINCHE_DATASET="chinche_ml_dataset"
export CHINCHE_WORK_ROOT="$HOME/chinche-training"

# Existing reusable EC2 host. The runner records these values but does not
# resize the host itself.
export CHINCHE_INSTANCE_ID=""
export CHINCHE_INSTANCE_TYPE="m5.xlarge"

# Docker resource limits
export CHINCHE_CPUS="4"
export CHINCHE_MEMORY="14g"
export CHINCHE_SHM_SIZE="2g"

# Provisional dataset schema and temporal roles
export CHINCHE_TARGET_COLUMN="target"
export CHINCHE_PERIOD_COLUMN="zafra"
export CHINCHE_DATE_COLUMN="prediction_date"
export CHINCHE_ROW_ID_COLUMN="record_id"
export CHINCHE_TRAIN_PERIODS="2019,2020,2021,2022,2023"
export CHINCHE_EVALUATION_PERIODS="2024,2025"
export CHINCHE_SCORING_PERIODS=""
export CHINCHE_CATEGORICAL_COLUMNS="ingenio,variedad,grupo_de_suelo"
export CHINCHE_METADATA_COLUMNS="lote"
export CHINCHE_FORBIDDEN_COLUMNS=""
export CHINCHE_EXCLUDE_FEATURES=""

# Provisional modeling choices
export CHINCHE_IMBALANCE="balanced"
export CHINCHE_OBJECTIVE_METRIC="average_precision"
export CHINCHE_THRESHOLD_STRATEGY="fixed"
export CHINCHE_FIXED_THRESHOLD="0.5"
export CHINCHE_MINIMUM_RECALL="0.85"
export CHINCHE_CALIBRATION="none"
