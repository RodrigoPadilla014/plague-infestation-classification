# Model 1 January — v001 dataset
# Source this file, then run: bash ec2/run_training.sh diagnostics [...]

# AWS and storage
export CHINCHE_BUCKET="eagriculturai-chinche"
export AWS_REGION="us-east-1"
export CHINCHE_IMAGE="<AWS_ACCOUNT_ID>.dkr.ecr.us-east-1.amazonaws.com/chinche-training:latest"
export CHINCHE_DATASET="ml_dataset_model1_january_v001"
export CHINCHE_WORK_ROOT="$HOME/chinche-training"

# EC2 host
export CHINCHE_INSTANCE_ID="<EC2_INSTANCE_ID>"
export CHINCHE_INSTANCE_TYPE="m5.xlarge"

# Docker resource limits
export CHINCHE_CPUS="4"
export CHINCHE_MEMORY="14g"
export CHINCHE_SHM_SIZE="2g"

# Dataset schema
export CHINCHE_TARGET_COLUMN="target"
export CHINCHE_PERIOD_COLUMN="target_rainy_year"
export CHINCHE_DATE_COLUMN="prediction_date"
export CHINCHE_ROW_ID_COLUMN="record_id"

# Temporal roles
# 2021 and 2022 dropped (R1 — incomplete data)
export CHINCHE_TRAIN_PERIODS="2019,2020,2023,2024,2025"
export CHINCHE_EVALUATION_PERIODS=""
export CHINCHE_SCORING_PERIODS=""

# String columns that are real features
export CHINCHE_CATEGORICAL_COLUMNS="prod_variedad,prod_grupo_de_suelo,prod_familia_de_suelo,prod_grupo_de_humedad,prod_no_corte,prod_codigo_zae,prod_estrato"

# Kept in prediction outputs but not used as features
export CHINCHE_METADATA_COLUMNS="lot_key"

# Forbidden: season-time leakage + location identifiers (R4) + target derivation metadata
export CHINCHE_FORBIDDEN_COLUMNS="target_max_ninfas_raw,target_max_valid_ninfas,target_plague_gt_050_raw,plague_zafras,n_observations,n_core_rainy_observations,n_edge_month_observations,n_nymph_observations_raw,n_valid_nymph_observations,n_possible_sampling_error,n_extreme_ninfas,n_ninfas_outlier,first_visit,last_visit,ingenio,mill_name,productivity_lot_key,target_status,target_year_rules"

# Excluded: not leaky but non-numeric and not useful as features
# (dates already resolved as crop_age_days_*; geometry columns are diagnostics)
export CHINCHE_EXCLUDE_FEATURES="prod_source_zafra,prod_cierre_date,crop_start_date,spatial_geometry_valid,spatial_geometry_empty"

# MLflow experiment tracking
# Leave MLFLOW_TRACKING_URI unset to log locally to ./mlruns
# Set to a remote server URI (e.g. http://host:5000) for shared tracking
export MLFLOW_TRACKING_URI=""
export MLFLOW_EXPERIMENT_NAME="model1_january"

# Modeling choices (TBD after diagnostics)
export CHINCHE_IMBALANCE="balanced"
export CHINCHE_OBJECTIVE_METRIC="average_precision"
export CHINCHE_THRESHOLD_STRATEGY="recall_constraint"
export CHINCHE_MINIMUM_RECALL="0.85"
export CHINCHE_CALIBRATION="none"
export CHINCHE_FIXED_THRESHOLD="0.5"
